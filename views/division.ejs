<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ESSPortal Division</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 24px; background: #f4f7fb; color: #0f172a; }
    .container { max-width: 760px; margin: 0 auto; background: #fff; padding: 24px; border-radius: 12px; box-shadow: 0 8px 24px rgba(15,23,42,0.08); }
    .button { display: inline-block; padding: 12px 18px; border-radius: 8px; background: #2563eb; color: #fff; text-decoration: none; margin-top: 16px; }
    .alert { border-radius: 10px; padding: 16px; margin: 18px 0; }
    .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
  </style>
</head>
<body>
  <div class="container">
    <h1><%= divisionName %></h1>
    <% if (matchTitle) { %>
      <p>Match: <strong><%= matchTitle %></strong></p>
    <% } %>
    <p>För att visa divisionens resultat behöver portalen verifiera dig med reCAPTCHA.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } else { %>
      <p>Laddar divisionens resultat. Om inget händer, klicka på knappen nedan för att starta verifiering.</p>
    <% } %>

    <form id="division-form" method="post" action="/division/fetch">
      <input type="hidden" name="matchUrl" value="<%= matchUrl %>" />
      <input type="hidden" name="divisionUrl" value="<%= divisionUrl %>" />
      <input type="hidden" name="divisionName" value="<%= divisionName %>" />
      <input type="hidden" name="g-recaptcha-response" id="g-recaptcha-response" />
      <button type="button" class="button" id="start-button">Hämta resultat</button>
    </form>

    <p style="margin-top: 24px;"><a href="/" class="button" style="background:#64748b;">Tillbaka till match</a></p>
  </div>

  <script src="https://www.google.com/recaptcha/api.js?render=<%= recaptchaSiteKey %>"></script>
  <script>
    const form = document.getElementById("division-form");
    const startButton = document.getElementById("start-button");

    async function executeRecaptcha() {
      try {
        const token = await grecaptcha.execute("<%= recaptchaSiteKey %>", { action: "submit" });
        document.getElementById("g-recaptcha-response").value = token;
        form.submit();
      } catch (err) {
        alert("Det gick inte att köra reCAPTCHA: " + err.message);
      }
    }

    startButton.addEventListener("click", executeRecaptcha);
  </script>
</body>
</html>
