<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Neon Scoreboard — Match Comparison</title>
  <style>
    :root {
      --bg-primary: #0a0e27;
      --bg-secondary: #1a0e3d;
      --bg-container: rgba(20, 10, 50, 0.6);
      --bg-input: rgba(10, 30, 60, 0.5);
      --bg-input-focus: rgba(10, 30, 60, 0.8);
      --text-primary: #e0e6ff;
      --text-secondary: #b0c4ff;
      --accent: #64d9ff;
      --accent-glow: rgba(100, 217, 255, 0.5);
      --border: rgba(100, 200, 255, 0.2);
      --border-hover: rgba(100, 217, 255, 0.6);
      --success: #00ff88;
      --row-even: rgba(0, 0, 0, 0.2);
      --row-hover: rgba(100, 217, 255, 0.1);
      --table-header: linear-gradient(90deg, rgba(100, 217, 255, 0.15), rgba(0, 102, 255, 0.1));
    }
    [data-theme="light"] {
      --bg-primary: #f0f4f8;
      --bg-secondary: #e2e8f0;
      --bg-container: rgba(255, 255, 255, 0.9);
      --bg-input: rgba(240, 244, 248, 0.8);
      --bg-input-focus: rgba(255, 255, 255, 1);
      --text-primary: #1a202c;
      --text-secondary: #4a5568;
      --accent: #0066ff;
      --accent-glow: rgba(0, 102, 255, 0.3);
      --border: rgba(0, 102, 255, 0.2);
      --border-hover: rgba(0, 102, 255, 0.5);
      --success: #059669;
      --row-even: rgba(0, 102, 255, 0.04);
      --row-hover: rgba(0, 102, 255, 0.08);
      --table-header: linear-gradient(90deg, rgba(0, 102, 255, 0.08), rgba(0, 102, 255, 0.04));
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
      background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 20px;
      transition: background 0.4s, color 0.4s;
    }
    .container {
      max-width: 1400px;
      margin: 0 auto;
      background: var(--bg-container);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      animation: slideIn 0.6s ease-out;
    }
    @keyframes slideIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    h1 {
      font-size: 2.5em; font-weight: 700;
      background: linear-gradient(120deg, #64d9ff, #0066ff, #ff00ff, #64d9ff);
      background-size: 300% 300%;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 10px;
      animation: gradient 8s ease infinite;
    }
    @keyframes gradient { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
    h2 { font-size: 1.5em; color: var(--accent); margin-top: 25px; margin-bottom: 15px; }
    p { font-size: 1.05em; margin-bottom: 15px; color: var(--text-secondary); }
    a { color: var(--accent); }
    label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--accent); font-size: 0.95em; }
    input[type=url] {
      width: 100%; padding: 12px 16px;
      border: 2px solid var(--border); border-radius: 10px;
      background: var(--bg-input); color: var(--text-primary);
      font-size: 1em; margin-bottom: 14px; font-family: inherit; transition: all 0.3s;
    }
    input[type=url]:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 20px var(--accent-glow); background: var(--bg-input-focus); }
    button {
      background: linear-gradient(135deg, #0066ff, #00d4ff);
      color: #fff; padding: 12px 28px; border: none; border-radius: 10px;
      cursor: pointer; font-size: 1em; font-weight: 600;
      transition: all 0.3s; box-shadow: 0 4px 15px rgba(0, 102, 255, 0.4);
    }
    button:hover { transform: translateY(-2px); box-shadow: 0 6px 25px rgba(0, 102, 255, 0.6); }
    .alert { border-radius: 12px; padding: 20px; margin: 20px 0; border: 2px solid #ff4444; background: rgba(255, 68, 68, 0.1); color: #ff9999; }
    .nav-link { display: inline-block; margin-bottom: 20px; color: var(--accent); text-decoration: none; font-weight: 600; }
    .nav-link:hover { text-decoration: underline; }
    .match-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0; }
    .match-card {
      background: linear-gradient(135deg, rgba(100, 217, 255, 0.1), rgba(0, 102, 255, 0.05));
      border: 2px solid var(--border); border-radius: 12px; padding: 20px; text-align: center;
    }
    .match-card h3 { color: var(--accent); margin-bottom: 8px; }
    .match-card .count { font-size: 2em; color: var(--success); font-weight: 700; }
    .badge-common { background: var(--success); color: #0a0e27; padding: 2px 8px; border-radius: 10px; font-size: 0.8em; font-weight: 700; }
    .badge-only1 { background: #64d9ff; color: #0a0e27; padding: 2px 8px; border-radius: 10px; font-size: 0.8em; font-weight: 700; }
    .badge-only2 { background: #ff6b9d; color: #0a0e27; padding: 2px 8px; border-radius: 10px; font-size: 0.8em; font-weight: 700; }
    table { width: 100%; border-collapse: collapse; margin-top: 16px; font-size: 0.9em; }
    th, td { border: 1px solid var(--border); padding: 10px; text-align: left; }
    th { background: var(--table-header); color: var(--accent); font-weight: 600; position: sticky; top: 0; }
    tbody tr:hover { background: var(--row-hover); }
    tbody tr:nth-child(even) { background: var(--row-even); }
    .improved { color: var(--success); font-weight: 600; }
    .declined { color: #ff6b9d; font-weight: 600; }
    .top-bar { display: flex; justify-content: flex-end; gap: 12px; margin-bottom: 16px; }
    .theme-toggle {
      background: var(--bg-input); border: 2px solid var(--border); color: var(--text-primary);
      padding: 8px 16px; border-radius: 8px; cursor: pointer; font-size: 0.9em; font-weight: 600;
      transition: all 0.3s; box-shadow: none;
    }
    .theme-toggle:hover { border-color: var(--accent); box-shadow: 0 0 10px var(--accent-glow); }
    .loading-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(5,5,20,0.85); backdrop-filter: blur(8px); z-index: 9999; justify-content: center; align-items: center; flex-direction: column; gap: 24px; }
    .loading-overlay.active { display: flex; }
    .loading-spinner { width: 60px; height: 60px; border: 4px solid rgba(100,217,255,0.15); border-top-color: #64d9ff; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-text { font-size: 1.3em; font-weight: 600; color: var(--accent); }
    .loading-sub { font-size: 0.9em; color: var(--text-secondary); opacity: 0.7; }
    @media (max-width: 768px) {
      .container { padding: 25px; }
      h1 { font-size: 1.8em; }
      .match-cards { grid-template-columns: 1fr; }
      table { font-size: 0.8em; }
      th, td { padding: 6px; }
    }
  </style>
</head>
<body>
  <div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <div class="loading-text" id="loadingText">Comparing matches...</div>
    <div class="loading-sub">This may take a while if matches need to be fetched</div>
  </div>

  <div class="container">
    <div class="top-bar">
      <button class="theme-toggle" id="themeToggle">🌙 Dark</button>
    </div>
    <a href="/" class="nav-link">← Back to Scoreboard</a>
    <h1>🔀 Match Comparison</h1>
    <p>Compare shooter performances across two matches</p>

    <form method="post" id="compareForm">
      <label for="match_url_1">Match 1</label>
      <input id="match_url_1" name="match_url_1" type="url" placeholder="https://portal.ipscess.org/portal/match/..." value="<%= matchUrl1 %>" required>
      <label for="match_url_2">Match 2</label>
      <input id="match_url_2" name="match_url_2" type="url" placeholder="https://portal.ipscess.org/portal/match/..." value="<%= matchUrl2 %>" required>
      <button type="submit">🔀 Compare</button>
    </form>

    <% if (error) { %>
      <div class="alert">❌ <%= error %></div>
    <% } %>

    <% if (comparison) { %>
      <h2>📊 Overview</h2>
      <div class="match-cards">
        <div class="match-card">
          <h3><%= comparison.match1.title %></h3>
          <div class="count"><%= comparison.match1.shooterCount %></div>
          <p>competitors</p>
        </div>
        <div class="match-card">
          <h3><%= comparison.match2.title %></h3>
          <div class="count"><%= comparison.match2.shooterCount %></div>
          <p>competitors</p>
        </div>
      </div>

      <p>
        <span class="badge-common"><%= comparison.common.length %> common</span>
        <span class="badge-only1"><%= comparison.onlyMatch1.length %> only in Match 1</span>
        <span class="badge-only2"><%= comparison.onlyMatch2.length %> only in Match 2</span>
      </p>

      <% if (comparison.common.length > 0) { %>
        <h2>🎯 Common Shooters (<%= comparison.common.length %>)</h2>
        <div style="overflow-x: auto;">
        <table>
          <thead>
            <tr>
              <th>Shooter</th>
              <th>Division (M1)</th>
              <th>Place (M1)</th>
              <th>Score % (M1)</th>
              <th>Division (M2)</th>
              <th>Place (M2)</th>
              <th>Score % (M2)</th>
            </tr>
          </thead>
          <tbody>
            <% comparison.common.forEach((s) => { %>
              <tr>
                <td><strong><%= s.name %></strong></td>
                <td><%= s.match1.division %></td>
                <td><%= s.match1.place %></td>
                <td><%= s.match1.scorePercent %></td>
                <td><%= s.match2.division %></td>
                <td><%= s.match2.place %></td>
                <td><%= s.match2.scorePercent %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
        </div>
      <% } %>

      <% if (comparison.onlyMatch1.length > 0) { %>
        <h2>Only in <%= comparison.match1.title %> (<%= comparison.onlyMatch1.length %>)</h2>
        <div style="overflow-x: auto;">
        <table>
          <thead><tr><th>Shooter</th><th>Division</th><th>Place</th><th>Score %</th></tr></thead>
          <tbody>
            <% comparison.onlyMatch1.forEach((s) => { %>
              <tr>
                <td><%= s.name %></td>
                <td><%= s.match1.division %></td>
                <td><%= s.match1.place %></td>
                <td><%= s.match1.scorePercent %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
        </div>
      <% } %>

      <% if (comparison.onlyMatch2.length > 0) { %>
        <h2>Only in <%= comparison.match2.title %> (<%= comparison.onlyMatch2.length %>)</h2>
        <div style="overflow-x: auto;">
        <table>
          <thead><tr><th>Shooter</th><th>Division</th><th>Place</th><th>Score %</th></tr></thead>
          <tbody>
            <% comparison.onlyMatch2.forEach((s) => { %>
              <tr>
                <td><%= s.name %></td>
                <td><%= s.match2.division %></td>
                <td><%= s.match2.place %></td>
                <td><%= s.match2.scorePercent %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
        </div>
      <% } %>
    <% } %>
  </div>

  <script>
    (function() {
      const toggle = document.getElementById('themeToggle');
      const saved = localStorage.getItem('theme') || 'dark';
      if (saved === 'light') { document.documentElement.setAttribute('data-theme', 'light'); toggle.textContent = '☀️ Light'; }
      toggle.addEventListener('click', function() {
        const current = document.documentElement.getAttribute('data-theme');
        if (current === 'light') { document.documentElement.removeAttribute('data-theme'); localStorage.setItem('theme', 'dark'); toggle.textContent = '🌙 Dark'; }
        else { document.documentElement.setAttribute('data-theme', 'light'); localStorage.setItem('theme', 'light'); toggle.textContent = '☀️ Light'; }
      });
    })();
    const form = document.getElementById('compareForm');
    if (form) {
      form.addEventListener('submit', function() {
        const overlay = document.getElementById('loadingOverlay');
        overlay.classList.add('active');
      });
    }
  </script>
</body>
</html>
