<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Neon Scoreboard — IPSC Match Results</title>
  <style>
    :root {
      --bg-primary: #0a0e27;
      --bg-secondary: #1a0e3d;
      --bg-container: rgba(20, 10, 50, 0.6);
      --bg-input: rgba(10, 30, 60, 0.5);
      --bg-input-focus: rgba(10, 30, 60, 0.8);
      --text-primary: #e0e6ff;
      --text-secondary: #b0c4ff;
      --accent: #64d9ff;
      --accent-glow: rgba(100, 217, 255, 0.5);
      --border: rgba(100, 200, 255, 0.2);
      --border-hover: rgba(100, 217, 255, 0.6);
      --success: #00ff88;
      --row-even: rgba(0, 0, 0, 0.2);
      --row-hover: rgba(100, 217, 255, 0.1);
      --table-header: linear-gradient(90deg, rgba(100, 217, 255, 0.15), rgba(0, 102, 255, 0.1));
    }
    [data-theme="light"] {
      --bg-primary: #f0f4f8;
      --bg-secondary: #e2e8f0;
      --bg-container: rgba(255, 255, 255, 0.9);
      --bg-input: rgba(240, 244, 248, 0.8);
      --bg-input-focus: rgba(255, 255, 255, 1);
      --text-primary: #1a202c;
      --text-secondary: #4a5568;
      --accent: #0066ff;
      --accent-glow: rgba(0, 102, 255, 0.3);
      --border: rgba(0, 102, 255, 0.2);
      --border-hover: rgba(0, 102, 255, 0.5);
      --success: #059669;
      --row-even: rgba(0, 102, 255, 0.04);
      --row-hover: rgba(0, 102, 255, 0.08);
      --table-header: linear-gradient(90deg, rgba(0, 102, 255, 0.08), rgba(0, 102, 255, 0.04));
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
      background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 20px;
      transition: background 0.4s, color 0.4s;
    }
    .container {
      max-width: 1400px;
      margin: 0 auto;
      background: var(--bg-container);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.1);
      animation: slideIn 0.6s ease-out;
      transition: background 0.4s, border-color 0.4s;
    }
    @keyframes slideIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    h1 {
      font-size: 3em;
      font-weight: 700;
      background: linear-gradient(120deg, #64d9ff, #0066ff, #ff00ff, #64d9ff);
      background-size: 300% 300%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 10px;
      animation: gradient 8s ease infinite;
    }
    @keyframes gradient {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    h2 { font-size: 1.8em; color: var(--accent); margin-top: 30px; margin-bottom: 20px; font-weight: 600; }
    h3 { font-size: 1.3em; color: var(--accent); margin-top: 20px; margin-bottom: 12px; }
    p { font-size: 1.05em; margin-bottom: 15px; color: var(--text-secondary); }
    label { display: block; margin-bottom: 10px; font-weight: 600; color: var(--accent); font-size: 0.95em; }
    input[type=url] {
      width: 100%;
      padding: 14px 18px;
      border: 2px solid var(--border);
      border-radius: 10px;
      background: var(--bg-input);
      color: var(--text-primary);
      font-size: 1em;
      margin-bottom: 18px;
      transition: all 0.3s;
      font-family: inherit;
    }
    input[type=url]:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 20px var(--accent-glow);
      background: var(--bg-input-focus);
    }
    button {
      background: linear-gradient(135deg, #0066ff, #00d4ff);
      color: #fff;
      padding: 14px 30px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-size: 1em;
      font-weight: 600;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(0, 102, 255, 0.4);
    }
    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(0, 102, 255, 0.6);
    }
    button:active {
      transform: translateY(0);
    }
    .alert {
      border-radius: 12px;
      padding: 20px;
      margin: 20px 0;
      border: 2px solid #ff4444;
      background: rgba(255, 68, 68, 0.1);
      color: #ff9999;
    }
    .division-buttons {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 12px;
      margin-top: 18px;
    }
    .div-btn {
      display: inline-block;
      padding: 12px 16px;
      border-radius: 10px;
      background: linear-gradient(135deg, rgba(100, 217, 255, 0.2), rgba(0, 102, 255, 0.2));
      color: var(--accent);
      text-decoration: none;
      border: 2px solid var(--border-hover);
      font-weight: 600;
      transition: all 0.3s;
      text-align: center;
      cursor: pointer;
    }
    .div-btn:hover {
      border-color: var(--accent);
      background: linear-gradient(135deg, rgba(100, 217, 255, 0.4), rgba(0, 102, 255, 0.3));
      box-shadow: 0 0 15px var(--accent-glow);
      transform: translateY(-3px);
    }
    .combined-btn {
      background: linear-gradient(135deg, rgba(0, 255, 136, 0.2), rgba(0, 200, 100, 0.2));
      color: var(--success);
      border-color: rgba(0, 255, 136, 0.4);
    }
    .combined-btn:hover {
      border-color: var(--success);
      background: linear-gradient(135deg, rgba(0, 255, 136, 0.4), rgba(0, 200, 100, 0.3));
      box-shadow: 0 0 15px rgba(0, 255, 136, 0.5);
    }
    .summary-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      margin-top: 20px;
    }
    .card {
      background: linear-gradient(135deg, rgba(100, 217, 255, 0.1), rgba(0, 102, 255, 0.05));
      border: 2px solid rgba(100, 217, 255, 0.2);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      transition: all 0.3s;
    }
    .card:hover {
      border-color: rgba(100, 217, 255, 0.6);
      box-shadow: 0 0 20px rgba(100, 217, 255, 0.3);
      transform: translateY(-5px);
    }
    .card strong { color: var(--accent); font-size: 0.9em; display: block; margin-bottom: 8px; }
    .card div { font-size: 1.8em; color: var(--success); font-weight: 700; }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 24px;
      font-size: 0.95em;
      overflow-x: auto;
    }
    th, td {
      border: 1px solid var(--border);
      padding: 12px;
      text-align: left;
    }
    th {
      background: var(--table-header);
      color: var(--accent);
      font-weight: 600;
      position: sticky;
      top: 0;
    }
    tbody tr {
      transition: all 0.2s;
    }
    tbody tr:hover {
      background: var(--row-hover);
    }
    tbody tr:nth-child(even) {
      background: var(--row-even);
    }
    .stats-table {
      font-size: 0.9em;
    }
    .preload-badge {
      display: inline-block;
      background: linear-gradient(135deg, #00ff88, #00d4ff);
      color: #0a0e27;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.8em;
      font-weight: 700;
      margin-left: 10px;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.6; }
    }
    /* Loading overlay */
    .loading-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(5, 5, 20, 0.85);
      backdrop-filter: blur(8px);
      z-index: 9999;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      gap: 24px;
    }
    .loading-overlay.active {
      display: flex;
    }
    .loading-spinner {
      width: 60px;
      height: 60px;
      border: 4px solid rgba(100, 217, 255, 0.15);
      border-top-color: #64d9ff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .loading-text {
      font-size: 1.3em;
      font-weight: 600;
      color: var(--accent);
      text-align: center;
      animation: pulse 2s ease-in-out infinite;
    }
    .loading-sub {
      font-size: 0.9em;
      color: var(--text-secondary);
      opacity: 0.7;
    }
    /* Theme toggle */
    .top-bar {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .theme-toggle {
      background: var(--bg-input);
      border: 2px solid var(--border);
      color: var(--text-primary);
      padding: 8px 16px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.9em;
      font-weight: 600;
      transition: all 0.3s;
      box-shadow: none;
    }
    .theme-toggle:hover {
      border-color: var(--accent);
      box-shadow: 0 0 10px var(--accent-glow);
      transform: translateY(-1px);
    }
    /* Toolbar (search + export) */
    .toolbar {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }
    .search-box {
      flex: 1;
      min-width: 200px;
      padding: 10px 14px;
      border: 2px solid var(--border);
      border-radius: 8px;
      background: var(--bg-input);
      color: var(--text-primary);
      font-size: 0.95em;
      font-family: inherit;
      transition: all 0.3s;
    }
    .search-box:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 15px var(--accent-glow);
      background: var(--bg-input-focus);
    }
    .toolbar-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 18px;
      border-radius: 8px;
      border: 2px solid var(--border);
      background: var(--bg-input);
      color: var(--accent);
      font-weight: 600;
      font-size: 0.9em;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.3s;
      box-shadow: none;
    }
    .toolbar-btn:hover {
      border-color: var(--accent);
      box-shadow: 0 0 10px var(--accent-glow);
      transform: translateY(-1px);
    }
    .search-results {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg-container);
      border: 2px solid var(--border);
      border-radius: 8px;
      max-height: 300px;
      overflow-y: auto;
      z-index: 100;
      display: none;
      backdrop-filter: blur(20px);
    }
    .search-results.active { display: block; }
    .search-result-item {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: background 0.2s;
    }
    .search-result-item:hover { background: var(--row-hover); }
    .search-result-item:last-child { border-bottom: none; }
    .search-result-name { font-weight: 600; color: var(--text-primary); }
    .search-result-meta { font-size: 0.85em; color: var(--text-secondary); }
    .search-wrap { position: relative; flex: 1; min-width: 200px; }
    @media (max-width: 768px) {
      .container { padding: 25px; }
      h1 { font-size: 2em; }
      h2 { font-size: 1.4em; }
      input[type=url], button { font-size: 0.95em; padding: 12px 20px; }
      .division-buttons { grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 8px; }
      table { font-size: 0.85em; }
      th, td { padding: 8px; }
      .toolbar { flex-direction: column; }
    }
  </style>
</head>
<body>
  <!-- Loading overlay -->
  <div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <div class="loading-text" id="loadingText">Loading...</div>
    <div class="loading-sub" id="loadingSub">This may take a moment</div>
  </div>

  <div class="container">
    <div class="top-bar">
      <button class="theme-toggle" id="themeToggle" title="Toggle theme">🌙 Dark</button>
    </div>
    <h1>⚡ Neon Scoreboard</h1>
    <p>Enter match URL and unleash the competition data</p>
    <div style="margin-bottom: 20px; display: flex; gap: 16px; flex-wrap: wrap;">
      <a href="/compare" style="color: var(--accent); text-decoration: none; font-weight: 600;">🔀 Compare Matches</a>
      <a href="/history" style="color: var(--accent); text-decoration: none; font-weight: 600;">📚 Match History</a>
    </div>

    <form method="post">
      <label for="match_url">Match Link</label>
      <input id="match_url" name="match_url" type="url" placeholder="https://portal.ipscess.org/portal/match/..." value="<%= matchUrl %>" required>
      <button type="submit">⚡ Launch</button>
    </form>

    <% if (error) { %>
      <div class="alert">❌ <%= error %></div>
    <% } %>

    <% if (matchTitle) { %>
      <h2><%= matchTitle %><% if (typeof isPreloaded !== 'undefined' && isPreloaded) { %><span class="preload-badge">✓ Preloaded</span><% } %></h2>
    <% } %>

    <% if (divisionLinks && divisionLinks.length) { %>
      <div style="margin-top: 30px;">
        <h3>🏆 Select Division</h3>
        <div class="division-buttons">
          <% divisionLinks.forEach((division) => { %>
            <a href="/division?matchUrl=<%= encodeURIComponent(matchUrl) %>&divisionUrl=<%= encodeURIComponent(division.url) %>&divisionName=<%= encodeURIComponent(division.name) %>" class="div-btn"><%= division.name %></a>
          <% }); %>
          <a href="/combined?matchUrl=<%= encodeURIComponent(matchUrl) %>" class="div-btn combined-btn">📊 Combined</a>
        </div>
      </div>
    <% } %>

    <% if (selectedView) { %>
      <h2 style="margin-top: 30px;"><%= sectionTitle %> <small style="font-size: 0.7em; color: #64d9ff; opacity: 0.8;">[<%= selectedView === 'combined' ? '🌐 Combined' : '📍 Division' %>]</small></h2>
    <% } %>

    <% if (summary) { %>
      <h2 style="margin-top: 30px;">📈 Statistics</h2>
      <div class="summary-grid">
        <div class="card"><strong>Competitors</strong><div><%= summary.row_count %></div></div>
        <div class="card"><strong>Fields</strong><div><%= summary.columns.length %></div></div>
        <% if (summary.unique_matches !== undefined) { %>
          <div class="card"><strong>Unique Matches</strong><div><%= summary.unique_matches %></div></div>
        <% } %>
      </div>

      <% if (selectedView === 'combined' && Object.keys(summary.stats).length) { %>
        <h3>Performance Metrics</h3>
        <table class="stats-table">
          <thead>
            <tr><th>Field</th><th>Count</th><th>Mean</th><th>Min</th><th>Max</th></tr>
          </thead>
          <tbody>
            <% for (const [field, stats] of Object.entries(summary.stats)) { %>
              <tr>
                <td><%= field %></td>
                <td><%= stats.count %></td>
                <td><%= stats.mean.toFixed(2) %></td>
                <td><%= stats.min %></td>
                <td><%= stats.max %></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      <% } %>

      <% if (records && records.length) { %>
        <h2 style="margin-top: 30px;">🎯 Results</h2>
        <div class="toolbar">
          <div class="search-wrap">
            <input type="text" class="search-box" id="tableSearch" placeholder="🔍 Filter results..." autocomplete="off">
            <div class="search-results" id="searchResults"></div>
          </div>
          <a class="toolbar-btn" href="/export/csv?matchUrl=<%= encodeURIComponent(matchUrl) %>&view=<%= selectedView %><%= selectedView !== 'combined' && typeof divisionUrl !== 'undefined' ? '&divisionUrl=' + encodeURIComponent(divisionUrl) : '' %>">📥 CSV</a>
          <a class="toolbar-btn" href="/export/pdf?matchUrl=<%= encodeURIComponent(matchUrl) %>&view=<%= selectedView %><%= selectedView !== 'combined' && typeof divisionUrl !== 'undefined' ? '&divisionUrl=' + encodeURIComponent(divisionUrl) : '' %>">📄 PDF</a>
        </div>
        <div style="overflow-x: auto;">
        <table>
          <thead>
            <tr>
              <% const recordKeys = Object.keys(records[0]); %>
              <% if (selectedView === 'combined' && recordKeys.includes('Overall Place')) { %>
                <th>Overall Place</th>
                <% const remainingKeys = recordKeys.filter((key) => key !== 'Overall Place'); %>
                <% remainingKeys.forEach((key) => { %>
                  <th><%= key %></th>
                <% }); %>
              <% } else { %>
                <% recordKeys.forEach((key) => { %>
                  <th><%= key %></th>
                <% }); %>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% records.forEach((row) => { %>
              <tr>
                <% if (selectedView === 'combined' && recordKeys.includes('Overall Place')) { %>
                  <td><%= row['Overall Place'] %></td>
                  <% const remainingKeys = recordKeys.filter((key) => key !== 'Overall Place'); %>
                  <% remainingKeys.forEach((key) => { %>
                    <td><%= row[key] %></td>
                  <% }); %>
                <% } else { %>
                  <% recordKeys.forEach((key) => { %>
                    <td><%= row[key] %></td>
                  <% }); %>
                <% } %>
              </tr>
            <% }); %>
          </tbody>
        </table>
        </div>
      <% } %>
    <% } %>
  </div>

  <script>
    const overlay = document.getElementById('loadingOverlay');
    const loadingText = document.getElementById('loadingText');
    const loadingSub = document.getElementById('loadingSub');

    function showLoading(text, sub) {
      loadingText.textContent = text;
      loadingSub.textContent = sub || 'This may take a moment';
      overlay.classList.add('active');
    }

    // Form submit (Launch button)
    const form = document.querySelector('form');
    if (form) {
      form.addEventListener('submit', function(e) {
        const url = document.getElementById('match_url').value;
        if (!url) return;
        showLoading('⚡ Fetching match data...', 'Connecting to ESSPortal and preloading all divisions');
        // Cycle through status messages
        const messages = [
          ['⏳ Loading match overview...', 'Parsing match page'],
          ['📡 Fetching divisions...', 'Launching headless browser for each division'],
          ['🔄 Still working...', 'Large matches may take a while'],
          ['⚙️ Almost there...', 'Parsing results and collecting shooter data'],
        ];
        let i = 0;
        setInterval(function() {
          if (i < messages.length) {
            loadingText.textContent = messages[i][0];
            loadingSub.textContent = messages[i][1];
            i++;
          }
        }, 4000);
      });
    }

    // Division and Combined links
    document.querySelectorAll('.div-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        const isCombined = btn.classList.contains('combined-btn');
        const name = btn.textContent.trim();
        if (isCombined) {
          showLoading('📊 Loading combined results...', 'Aggregating all divisions and calculating rankings');
        } else {
          showLoading('🎯 Loading ' + name + '...', 'Fetching division results');
        }
      });
    });
  </script>

  <script>
    // Theme toggle
    (function() {
      const toggle = document.getElementById('themeToggle');
      const saved = localStorage.getItem('theme') || 'dark';
      if (saved === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
        toggle.textContent = '☀️ Light';
      }
      toggle.addEventListener('click', function() {
        const current = document.documentElement.getAttribute('data-theme');
        if (current === 'light') {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'dark');
          toggle.textContent = '🌙 Dark';
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
          localStorage.setItem('theme', 'light');
          toggle.textContent = '☀️ Light';
        }
      });
    })();

    // Table search / filter
    (function() {
      const input = document.getElementById('tableSearch');
      if (!input) return;
      const table = document.querySelector('table:not(.stats-table)');
      if (!table) return;
      const tbody = table.querySelector('tbody');
      if (!tbody) return;
      const rows = Array.from(tbody.querySelectorAll('tr'));

      input.addEventListener('input', function() {
        const q = this.value.toLowerCase().trim();
        rows.forEach(function(row) {
          const text = row.textContent.toLowerCase();
          row.style.display = q === '' || text.includes(q) ? '' : 'none';
        });
      });
    })();
  </script>
</body>
</html>
