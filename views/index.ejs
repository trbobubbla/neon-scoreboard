<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Neon Scoreboard — IPSC Match Results</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-primary: #0f1117;
      --bg-secondary: #161822;
      --bg-card: rgba(22, 24, 34, 0.95);
      --bg-input: rgba(255, 255, 255, 0.04);
      --bg-input-focus: rgba(255, 255, 255, 0.08);
      --text-primary: #eaedf3;
      --text-secondary: #8b92a5;
      --text-muted: #555d70;
      --accent: #3b82f6;
      --accent-hover: #60a5fa;
      --accent-subtle: rgba(59, 130, 246, 0.1);
      --accent-glow: rgba(59, 130, 246, 0.25);
      --border: rgba(255, 255, 255, 0.06);
      --border-hover: rgba(255, 255, 255, 0.12);
      --success: #22c55e;
      --success-subtle: rgba(34, 197, 94, 0.1);
      --row-even: rgba(255, 255, 255, 0.02);
      --row-hover: rgba(59, 130, 246, 0.06);
      --table-header-bg: rgba(255, 255, 255, 0.03);
      --shadow: 0 1px 3px rgba(0,0,0,0.3), 0 4px 20px rgba(0,0,0,0.2);
      --radius: 12px;
    }
    [data-theme="light"] {
      --bg-primary: #f8f9fb;
      --bg-secondary: #ffffff;
      --bg-card: rgba(255, 255, 255, 0.98);
      --bg-input: rgba(0, 0, 0, 0.03);
      --bg-input-focus: rgba(0, 0, 0, 0.05);
      --text-primary: #111827;
      --text-secondary: #6b7280;
      --text-muted: #9ca3af;
      --accent: #2563eb;
      --accent-hover: #3b82f6;
      --accent-subtle: rgba(37, 99, 235, 0.06);
      --accent-glow: rgba(37, 99, 235, 0.15);
      --border: rgba(0, 0, 0, 0.06);
      --border-hover: rgba(0, 0, 0, 0.12);
      --success: #16a34a;
      --success-subtle: rgba(22, 163, 74, 0.06);
      --row-even: rgba(0, 0, 0, 0.015);
      --row-hover: rgba(37, 99, 235, 0.04);
      --table-header-bg: rgba(0, 0, 0, 0.02);
      --shadow: 0 1px 3px rgba(0,0,0,0.05), 0 4px 20px rgba(0,0,0,0.04);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      transition: background 0.3s, color 0.3s;
    }

    /* Top Navigation Bar */
    .topnav {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg-secondary);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(16px);
      padding: 0 24px;
    }
    .topnav-inner {
      max-width: 1440px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      height: 56px;
    }
    .topnav-brand {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; color: var(--text-primary);
      font-weight: 700; font-size: 1.05em; letter-spacing: -0.01em;
    }
    .topnav-brand svg { width: 22px; height: 22px; }
    .topnav-links {
      display: flex; align-items: center; gap: 6px;
    }
    .topnav-link {
      padding: 6px 12px; border-radius: 8px; font-size: 0.875em;
      color: var(--text-secondary); text-decoration: none; font-weight: 500;
      transition: all 0.15s;
    }
    .topnav-link:hover { color: var(--text-primary); background: var(--bg-input); }
    .theme-toggle {
      background: none; border: 1px solid var(--border);
      color: var(--text-secondary); padding: 6px 10px;
      border-radius: 8px; cursor: pointer; font-size: 0.85em;
      transition: all 0.15s; line-height: 1;
    }
    .theme-toggle:hover { border-color: var(--border-hover); color: var(--text-primary); }

    /* Main Content */
    .main { max-width: 1440px; margin: 0 auto; padding: 32px 24px; }

    /* Hero / Input Section */
    .hero {
      max-width: 640px; margin: 0 auto 40px;
      text-align: center;
    }
    .hero h1 {
      font-size: 2em; font-weight: 700; letter-spacing: -0.03em;
      margin-bottom: 8px; color: var(--text-primary);
    }
    .hero p { color: var(--text-secondary); font-size: 0.95em; margin-bottom: 24px; }
    .input-group {
      display: flex; gap: 8px;
    }
    .input-group input[type=url] {
      flex: 1; padding: 10px 16px;
      border: 1px solid var(--border); border-radius: 10px;
      background: var(--bg-input); color: var(--text-primary);
      font-size: 0.95em; font-family: inherit;
      transition: all 0.15s;
    }
    .input-group input[type=url]:focus {
      outline: none; border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
      background: var(--bg-input-focus);
    }
    .input-group input[type=url]::placeholder { color: var(--text-muted); }
    .btn-primary {
      padding: 10px 24px; border: none; border-radius: 10px;
      background: var(--accent); color: #fff;
      font-size: 0.95em; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: all 0.15s; white-space: nowrap;
    }
    .btn-primary:hover { background: var(--accent-hover); }

    /* Alert */
    .alert {
      max-width: 640px; margin: -16px auto 32px;
      padding: 12px 16px; border-radius: var(--radius);
      background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2);
      color: #f87171; font-size: 0.9em;
    }

    /* Match Header */
    .match-header {
      display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
      margin-bottom: 24px;
    }
    .match-header h2 {
      font-size: 1.5em; font-weight: 700; letter-spacing: -0.02em;
      color: var(--text-primary); margin: 0;
    }
    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 3px 10px; border-radius: 20px;
      font-size: 0.75em; font-weight: 600;
    }
    .badge-success { background: var(--success-subtle); color: var(--success); }
    .btn-icon {
      display: inline-flex; align-items: center; justify-content: center;
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--bg-input); border: 1px solid var(--border);
      color: var(--text-secondary); cursor: pointer;
      font-size: 0.85em; transition: all 0.15s;
    }
    .btn-icon:hover { border-color: var(--border-hover); color: var(--text-primary); background: var(--bg-input-focus); }

    /* Division Grid */
    .section-label {
      font-size: 0.75em; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 12px;
    }
    .division-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 8px; margin-bottom: 32px;
    }
    .div-btn {
      display: flex; align-items: center; justify-content: center;
      padding: 10px 14px; border-radius: 10px;
      background: var(--bg-input); border: 1px solid var(--border);
      color: var(--text-primary); text-decoration: none;
      font-weight: 500; font-size: 0.9em;
      transition: all 0.15s; text-align: center;
    }
    .div-btn:hover {
      border-color: var(--accent); background: var(--accent-subtle);
      color: var(--accent);
    }
    .combined-btn {
      border-color: rgba(34, 197, 94, 0.2);
      color: var(--success); font-weight: 600;
    }
    .combined-btn:hover {
      border-color: var(--success); background: var(--success-subtle);
    }

    /* View Header */
    .view-tag {
      display: inline-block; padding: 2px 8px; border-radius: 6px;
      font-size: 0.7em; font-weight: 600; vertical-align: middle;
      margin-left: 8px;
    }
    .view-tag-division { background: var(--accent-subtle); color: var(--accent); }
    .view-tag-combined { background: var(--success-subtle); color: var(--success); }

    /* Toolbar */
    .toolbar {
      display: flex; gap: 8px; align-items: center;
      flex-wrap: wrap; margin-bottom: 16px;
    }
    .search-wrap { position: relative; flex: 1; min-width: 200px; }
    .search-box {
      width: 100%; padding: 9px 14px 9px 36px;
      border: 1px solid var(--border); border-radius: 10px;
      background: var(--bg-input); color: var(--text-primary);
      font-size: 0.9em; font-family: inherit; transition: all 0.15s;
    }
    .search-box:focus {
      outline: none; border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
    .search-box::placeholder { color: var(--text-muted); }
    .search-icon {
      position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
      color: var(--text-muted); font-size: 0.85em; pointer-events: none;
    }
    .toolbar-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 16px; border-radius: 10px;
      border: 1px solid var(--border); background: var(--bg-input);
      color: var(--text-secondary); font-weight: 500; font-size: 0.85em;
      cursor: pointer; text-decoration: none; transition: all 0.15s;
    }
    .toolbar-btn:hover {
      border-color: var(--border-hover); color: var(--text-primary); background: var(--bg-input-focus);
    }

    /* Competitor Count */
    .result-meta {
      font-size: 0.85em; color: var(--text-muted); margin-bottom: 12px;
    }

    /* Table */
    .table-wrap {
      border: 1px solid var(--border); border-radius: var(--radius);
      overflow: hidden; margin-bottom: 32px;
    }
    .table-scroll { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875em; }
    th, td { padding: 10px 14px; text-align: left; white-space: nowrap; }
    th {
      background: var(--table-header-bg); color: var(--text-secondary);
      font-weight: 600; font-size: 0.8em; text-transform: uppercase;
      letter-spacing: 0.04em; border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 1;
    }
    td { border-bottom: 1px solid var(--border); color: var(--text-primary); }
    tbody tr { transition: background 0.1s; }
    tbody tr:hover { background: var(--row-hover); }
    tbody tr:nth-child(even) { background: var(--row-even); }
    tbody tr:nth-child(even):hover { background: var(--row-hover); }
    tbody tr:last-child td { border-bottom: none; }

    /* Loading Overlay */
    .loading-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(6px);
      z-index: 9999; justify-content: center; align-items: center;
      flex-direction: column; gap: 20px;
    }
    .loading-overlay.active { display: flex; }
    .loading-spinner {
      width: 40px; height: 40px;
      border: 3px solid var(--border); border-top-color: var(--accent);
      border-radius: 50%; animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-text { font-size: 1.1em; font-weight: 600; color: var(--text-primary); }
    .loading-sub { font-size: 0.85em; color: var(--text-muted); }

    /* Search Results Dropdown */
    .search-results {
      position: absolute; top: 100%; left: 0; right: 0;
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 10px; max-height: 280px; overflow-y: auto;
      z-index: 100; display: none; margin-top: 4px;
      box-shadow: var(--shadow);
    }
    .search-results.active { display: block; }
    .search-result-item {
      padding: 10px 14px; border-bottom: 1px solid var(--border);
      cursor: pointer; transition: background 0.1s;
    }
    .search-result-item:hover { background: var(--row-hover); }
    .search-result-item:last-child { border-bottom: none; }
    .search-result-name { font-weight: 600; color: var(--text-primary); font-size: 0.9em; }
    .search-result-meta { font-size: 0.8em; color: var(--text-secondary); }

    /* Shooter Detail Panel */
    .shooter-row { cursor: pointer; }
    .shooter-row:hover { background: var(--row-hover) !important; }
    .detail-row { display: none; }
    .detail-row.active { display: table-row; }
    .detail-row td { padding: 0; border-bottom: 1px solid var(--border); }
    .detail-panel {
      padding: 16px 20px;
      background: var(--bg-secondary);
      border-top: 1px solid var(--border);
    }
    .detail-panel-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 12px;
    }
    .detail-panel-header h3 {
      font-size: 0.95em; font-weight: 700; color: var(--text-primary);
    }
    .detail-panel-header .detail-close {
      background: none; border: none; color: var(--text-muted);
      cursor: pointer; font-size: 1.1em; padding: 4px; line-height: 1;
    }
    .detail-panel-header .detail-close:hover { color: var(--text-primary); }
    .detail-loading {
      font-size: 0.85em; color: var(--text-muted); padding: 8px 0;
    }
    .detail-stages {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 10px;
    }
    .stage-card {
      border: 1px solid var(--border); border-radius: 10px;
      padding: 12px 14px; background: var(--bg-primary);
    }
    .stage-card-name {
      font-size: 0.8em; font-weight: 700; color: var(--accent);
      margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.03em;
    }
    .stage-card-div {
      font-size: 0.7em; color: var(--text-muted); font-weight: 500;
      margin-bottom: 8px;
    }
    .stage-card-data {
      display: grid; grid-template-columns: 1fr 1fr; gap: 4px 12px;
      font-size: 0.82em;
    }
    .stage-card-data dt { color: var(--text-muted); font-weight: 500; }
    .stage-card-data dd { color: var(--text-primary); font-weight: 600; text-align: right; }
    .detail-empty {
      font-size: 0.85em; color: var(--text-muted); font-style: italic;
    }

    @media (max-width: 768px) {
      .main { padding: 20px 16px; }
      .hero h1 { font-size: 1.5em; }
      .input-group { flex-direction: column; }
      .division-grid { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); }
      table { font-size: 0.8em; }
      th, td { padding: 8px 10px; }
      .toolbar { flex-direction: column; }
      .topnav-inner { padding: 0; }
      .detail-stages { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <div class="loading-text" id="loadingText">Loading...</div>
    <div class="loading-sub" id="loadingSub">This may take a moment</div>
  </div>

  <nav class="topnav">
    <div class="topnav-inner">
      <a href="/" class="topnav-brand">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m8 12 3 3 5-5"/></svg>
        Neon Scoreboard
      </a>
      <div class="topnav-links">
        <a href="/history" class="topnav-link">History</a>
        <button class="theme-toggle" id="themeToggle" title="Toggle theme">🌙</button>
      </div>
    </div>
  </nav>

  <div class="main">
    <div class="hero">
      <h1>IPSC Match Results</h1>
      <p>Paste a match URL from ESSPortal to view detailed results</p>
      <form method="post">
        <div class="input-group">
          <input id="match_url" name="match_url" type="url" placeholder="https://portal.ipscess.org/portal/match/..." value="<%= matchUrl %>" required>
          <button type="submit" class="btn-primary">Load Match</button>
        </div>
      </form>
    </div>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <% if (matchTitle) { %>
      <div class="match-header">
        <h2><%= matchTitle %></h2>
        <% if (typeof isPreloaded !== 'undefined' && isPreloaded) { %>
          <span class="badge badge-success">Loaded</span>
        <% } %>
        <button class="btn-icon" onclick="reloadMatch()" title="Reload match data">&#x21bb;</button>
      </div>
    <% } %>

    <% if (divisionLinks && divisionLinks.length) { %>
      <div class="section-label">Divisions</div>
      <div class="division-grid">
        <% divisionLinks.forEach((division) => { %>
          <a href="/division?matchUrl=<%= encodeURIComponent(matchUrl) %>&divisionUrl=<%= encodeURIComponent(division.url) %>&divisionName=<%= encodeURIComponent(division.name) %>" class="div-btn"><%= division.name %></a>
        <% }); %>
        <a href="/combined?matchUrl=<%= encodeURIComponent(matchUrl) %>" class="div-btn combined-btn">Combined</a>
      </div>
    <% } %>

    <% if (selectedView) { %>
      <div class="match-header" style="margin-top: 8px;">
        <h2><%= sectionTitle %><span class="view-tag <%= selectedView === 'combined' ? 'view-tag-combined' : 'view-tag-division' %>"><%= selectedView === 'combined' ? 'Combined' : 'Division' %></span></h2>
      </div>
    <% } %>

    <% if (records && records.length) { %>
      <div class="toolbar">
        <div class="search-wrap">
          <span class="search-icon">&#x1F50D;</span>
          <input type="text" class="search-box" id="tableSearch" placeholder="Filter results..." autocomplete="off">
          <div class="search-results" id="searchResults"></div>
        </div>
        <a class="toolbar-btn" href="/export/csv?matchUrl=<%= encodeURIComponent(matchUrl) %>&view=<%= selectedView %><%= selectedView !== 'combined' && typeof divisionUrl !== 'undefined' ? '&divisionUrl=' + encodeURIComponent(divisionUrl) : '' %>">CSV</a>
        <a class="toolbar-btn" href="/export/pdf?matchUrl=<%= encodeURIComponent(matchUrl) %>&view=<%= selectedView %><%= selectedView !== 'combined' && typeof divisionUrl !== 'undefined' ? '&divisionUrl=' + encodeURIComponent(divisionUrl) : '' %>">PDF</a>
      </div>
      <div class="result-meta"><%= records.length %> competitors</div>
      <div class="table-wrap">
        <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <% const recordKeys = Object.keys(records[0]); %>
              <% if (selectedView === 'combined' && recordKeys.includes('Overall Place')) { %>
                <th>Overall Place</th>
                <% const remainingKeys = recordKeys.filter((key) => key !== 'Overall Place'); %>
                <% remainingKeys.forEach((key) => { %>
                  <th><%= key %></th>
                <% }); %>
              <% } else { %>
                <% recordKeys.forEach((key) => { %>
                  <th><%= key %></th>
                <% }); %>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% records.forEach((row, rowIdx) => { %>
              <tr class="shooter-row" data-shooter-id="<%= row['#'] || '' %>" data-row-idx="<%= rowIdx %>">
                <% if (selectedView === 'combined' && recordKeys.includes('Overall Place')) { %>
                  <td><%= row['Overall Place'] %></td>
                  <% const remainingKeys = recordKeys.filter((key) => key !== 'Overall Place'); %>
                  <% remainingKeys.forEach((key) => { %>
                    <td><%= row[key] %></td>
                  <% }); %>
                <% } else { %>
                  <% recordKeys.forEach((key) => { %>
                    <td><%= row[key] %></td>
                  <% }); %>
                <% } %>
              </tr>
              <tr class="detail-row" id="detail-<%= rowIdx %>">
                <td colspan="<%= recordKeys.length %>">
                  <div class="detail-panel">
                    <div class="detail-panel-header">
                      <h3>Stage Results — <%= row['Shooter'] || row['Name'] || '#' + (row['#'] || rowIdx) %></h3>
                      <button class="detail-close" onclick="closeDetail(<%= rowIdx %>)">&#x2715;</button>
                    </div>
                    <div class="detail-body" id="detail-body-<%= rowIdx %>">
                      <div class="detail-loading">Click to load stage data...</div>
                    </div>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
        </div>
      </div>
    <% } %>
  </div>

  <script>
    const overlay = document.getElementById('loadingOverlay');
    const loadingText = document.getElementById('loadingText');
    const loadingSub = document.getElementById('loadingSub');

    function showLoading(text, sub) {
      loadingText.textContent = text;
      loadingSub.textContent = sub || 'This may take a moment';
      overlay.classList.add('active');
    }

    function reloadMatch() {
      const urlInput = document.getElementById('match_url');
      if (!urlInput || !urlInput.value) return;
      showLoading('Reloading match data...', 'Fetching fresh data from ESSPortal');
      const form = document.querySelector('form');
      if (form) form.submit();
    }

    const form = document.querySelector('form');
    if (form) {
      form.addEventListener('submit', function(e) {
        const url = document.getElementById('match_url').value;
        if (!url) return;
        showLoading('Loading match data...', 'Connecting to ESSPortal');
        const messages = [
          ['Loading match overview...', 'Parsing match page'],
          ['Fetching divisions...', 'Launching headless browser for each division'],
          ['Still working...', 'Large matches may take a while'],
          ['Almost there...', 'Parsing results and collecting shooter data'],
        ];
        let i = 0;
        setInterval(function() {
          if (i < messages.length) {
            loadingText.textContent = messages[i][0];
            loadingSub.textContent = messages[i][1];
            i++;
          }
        }, 4000);
      });
    }

    document.querySelectorAll('.div-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const isCombined = btn.classList.contains('combined-btn');
        const name = btn.textContent.trim();
        showLoading(isCombined ? 'Loading combined results...' : 'Loading ' + name + '...', isCombined ? 'Aggregating all divisions' : 'Fetching division results');
      });
    });
  </script>

  <script>
    (function() {
      const toggle = document.getElementById('themeToggle');
      const saved = localStorage.getItem('theme') || 'dark';
      if (saved === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
        toggle.textContent = '☀️';
      }
      toggle.addEventListener('click', function() {
        const current = document.documentElement.getAttribute('data-theme');
        if (current === 'light') {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'dark');
          toggle.textContent = '🌙';
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
          localStorage.setItem('theme', 'light');
          toggle.textContent = '☀️';
        }
      });
    })();

    (function() {
      const input = document.getElementById('tableSearch');
      if (!input) return;
      const table = document.querySelector('table');
      if (!table) return;
      const tbody = table.querySelector('tbody');
      if (!tbody) return;
      const shooterRows = Array.from(tbody.querySelectorAll('tr.shooter-row'));
      input.addEventListener('input', function() {
        const q = this.value.toLowerCase().trim();
        shooterRows.forEach(function(row) {
          const visible = q === '' || row.textContent.toLowerCase().includes(q);
          row.style.display = visible ? '' : 'none';
          const detailRow = row.nextElementSibling;
          if (detailRow && detailRow.classList.contains('detail-row')) {
            if (!visible) detailRow.classList.remove('active');
          }
        });
      });
    })();

    // Shooter detail expand/collapse
    var detailCache = {};
    var matchUrlForApi = '<%= typeof matchUrl !== "undefined" ? matchUrl : "" %>';

    function closeDetail(idx) {
      var row = document.getElementById('detail-' + idx);
      if (row) row.classList.remove('active');
    }

    function renderStages(stages, container) {
      if (!stages || stages.length === 0) {
        container.innerHTML = '<div class="detail-empty">No stage data available for this shooter.</div>';
        return;
      }
      var skipKeys = ['#', 'Shooter', 'Name', 'Competitor', 'shooter_link', 'source_url'];
      var html = '<div class="detail-stages">';
      stages.forEach(function(s) {
        html += '<div class="stage-card">';
        html += '<div class="stage-card-name">' + escHtml(s.stage) + '</div>';
        html += '<div class="stage-card-div">' + escHtml(s.division) + '</div>';
        html += '<dl class="stage-card-data">';
        Object.keys(s.data).forEach(function(key) {
          if (skipKeys.indexOf(key) >= 0) return;
          var val = s.data[key];
          if (val === null || val === undefined || val === '') return;
          html += '<dt>' + escHtml(key) + '</dt><dd>' + escHtml(String(val)) + '</dd>';
        });
        html += '</dl></div>';
      });
      html += '</div>';
      container.innerHTML = html;
    }

    function escHtml(str) {
      var d = document.createElement('div');
      d.textContent = str;
      return d.innerHTML;
    }

    document.querySelectorAll('.shooter-row').forEach(function(row) {
      row.addEventListener('click', function() {
        var idx = row.getAttribute('data-row-idx');
        var shooterId = row.getAttribute('data-shooter-id');
        var detailRow = document.getElementById('detail-' + idx);
        if (!detailRow) return;

        // Toggle
        if (detailRow.classList.contains('active')) {
          detailRow.classList.remove('active');
          return;
        }

        // Close other open details
        document.querySelectorAll('.detail-row.active').forEach(function(r) { r.classList.remove('active'); });
        detailRow.classList.add('active');

        var body = document.getElementById('detail-body-' + idx);
        if (!body) return;

        // Check cache
        if (detailCache[shooterId]) {
          renderStages(detailCache[shooterId], body);
          return;
        }

        body.innerHTML = '<div class="detail-loading">Loading stage data...</div>';

        fetch('/api/shooter?matchUrl=' + encodeURIComponent(matchUrlForApi) + '&id=' + encodeURIComponent(shooterId))
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.error) {
              body.innerHTML = '<div class="detail-empty">' + escHtml(data.error) + '</div>';
              return;
            }
            detailCache[shooterId] = data.stages;
            renderStages(data.stages, body);
          })
          .catch(function(err) {
            body.innerHTML = '<div class="detail-empty">Failed to load data.</div>';
          });
      });
    });
  </script>
</body>
</html>
