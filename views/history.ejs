<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Neon Scoreboard — Match History</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-primary: #0f1117;
      --bg-secondary: #161822;
      --bg-card: rgba(22, 24, 34, 0.95);
      --bg-input: rgba(255, 255, 255, 0.04);
      --text-primary: #eaedf3;
      --text-secondary: #8b92a5;
      --text-muted: #555d70;
      --accent: #3b82f6;
      --accent-hover: #60a5fa;
      --accent-subtle: rgba(59, 130, 246, 0.1);
      --accent-glow: rgba(59, 130, 246, 0.25);
      --border: rgba(255, 255, 255, 0.06);
      --border-hover: rgba(255, 255, 255, 0.12);
      --shadow: 0 1px 3px rgba(0,0,0,0.3), 0 4px 20px rgba(0,0,0,0.2);
      --radius: 12px;
    }
    [data-theme="light"] {
      --bg-primary: #f8f9fb;
      --bg-secondary: #ffffff;
      --bg-card: rgba(255, 255, 255, 0.98);
      --bg-input: rgba(0, 0, 0, 0.03);
      --text-primary: #111827;
      --text-secondary: #6b7280;
      --text-muted: #9ca3af;
      --accent: #2563eb;
      --accent-hover: #3b82f6;
      --accent-subtle: rgba(37, 99, 235, 0.06);
      --accent-glow: rgba(37, 99, 235, 0.15);
      --border: rgba(0, 0, 0, 0.06);
      --border-hover: rgba(0, 0, 0, 0.12);
      --shadow: 0 1px 3px rgba(0,0,0,0.05), 0 4px 20px rgba(0,0,0,0.04);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      transition: background 0.3s, color 0.3s;
    }
    .topnav {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg-secondary);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(16px);
      padding: 0 24px;
    }
    .topnav-inner {
      max-width: 960px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      height: 56px;
    }
    .topnav-brand {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; color: var(--text-primary);
      font-weight: 700; font-size: 1.05em; letter-spacing: -0.01em;
    }
    .topnav-brand svg { width: 22px; height: 22px; }
    .topnav-links { display: flex; align-items: center; gap: 6px; }
    .topnav-link {
      padding: 6px 12px; border-radius: 8px; font-size: 0.875em;
      color: var(--text-secondary); text-decoration: none; font-weight: 500;
      transition: all 0.15s;
    }
    .topnav-link:hover { color: var(--text-primary); background: var(--bg-input); }
    .topnav-link.active { color: var(--accent); }
    .theme-toggle {
      background: none; border: 1px solid var(--border);
      color: var(--text-secondary); padding: 6px 10px;
      border-radius: 8px; cursor: pointer; font-size: 0.85em;
      transition: all 0.15s; line-height: 1;
    }
    .theme-toggle:hover { border-color: var(--border-hover); color: var(--text-primary); }

    .main { max-width: 960px; margin: 0 auto; padding: 32px 24px; }
    .page-header { margin-bottom: 32px; }
    .page-header h1 { font-size: 1.75em; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 6px; }
    .page-header p { color: var(--text-secondary); font-size: 0.95em; }

    .match-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .match-item {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 12px;
      padding: 16px 20px;
      border: 1px solid var(--border); border-radius: var(--radius);
      background: var(--bg-secondary);
      transition: all 0.15s;
    }
    .match-item:hover { border-color: var(--border-hover); }
    .match-title { font-weight: 600; color: var(--text-primary); font-size: 0.95em; }
    .match-date { font-size: 0.8em; color: var(--text-muted); margin-top: 2px; }
    .match-actions { display: flex; gap: 8px; align-items: center; }
    .match-actions a, .match-actions button {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 7px 18px; border-radius: 8px;
      font-weight: 600; font-size: 0.85em;
      transition: all 0.15s; cursor: pointer; border: none;
    }
    .match-actions a {
      background: var(--accent); color: #fff; text-decoration: none;
    }
    .match-actions a:hover { background: var(--accent-hover); }
    .btn-delete {
      background: transparent; color: var(--text-muted);
      border: 1px solid var(--border) !important;
    }
    .btn-delete:hover { color: #ef4444; border-color: #ef4444 !important; }
    .empty { text-align: center; padding: 60px 20px; color: var(--text-muted); font-size: 0.95em; }
    .empty a { color: var(--accent); text-decoration: none; font-weight: 500; }
    .empty a:hover { text-decoration: underline; }

    @media (max-width: 768px) {
      .main { padding: 20px 16px; }
      .page-header h1 { font-size: 1.4em; }
    }
  </style>
</head>
<body>
  <nav class="topnav">
    <div class="topnav-inner">
      <a href="/" class="topnav-brand">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m8 12 3 3 5-5"/></svg>
        Neon Scoreboard
      </a>
      <div class="topnav-links">
        <a href="/history" class="topnav-link active">History</a>
        <button class="theme-toggle" id="themeToggle" title="Toggle theme">🌙</button>
      </div>
    </div>
  </nav>

  <div class="main">
    <div class="page-header">
      <h1>Match History</h1>
      <p>Previously loaded matches stored locally</p>
    </div>

    <% if (matches && matches.length > 0) { %>
      <ul class="match-list">
        <% matches.forEach((m) => { %>
          <li class="match-item">
            <div>
              <div class="match-title"><%= m.title || 'Untitled Match' %></div>
              <div class="match-date">Saved: <%= m.fetched_at %></div>
            </div>
            <div class="match-actions">
              <a href="/history/load?url=<%= encodeURIComponent(m.url) %>">Load</a>
              <form method="POST" action="/history/delete" onsubmit="return confirm('Ta bort denna match?')">
                <input type="hidden" name="url" value="<%= m.url %>">
                <button type="submit" class="btn-delete" title="Ta bort">&#x1F5D1;</button>
              </form>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <div class="empty">
        <p>No matches saved yet. Load a match from the <a href="/">scoreboard</a> and it will appear here.</p>
      </div>
    <% } %>
  </div>

  <script>
    (function() {
      const toggle = document.getElementById('themeToggle');
      const saved = localStorage.getItem('theme') || 'dark';
      if (saved === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
        toggle.textContent = '☀️';
      }
      toggle.addEventListener('click', function() {
        const current = document.documentElement.getAttribute('data-theme');
        if (current === 'light') {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'dark');
          toggle.textContent = '🌙';
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
          localStorage.setItem('theme', 'light');
          toggle.textContent = '☀️';
        }
      });
    })();
  </script>
</body>
</html>
