<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Neon Scoreboard — Match History</title>
  <style>
    :root {
      --bg-primary: #0a0e27;
      --bg-secondary: #1a0e3d;
      --bg-container: rgba(20, 10, 50, 0.6);
      --text-primary: #e0e6ff;
      --text-secondary: #b0c4ff;
      --accent: #64d9ff;
      --accent-glow: rgba(100, 217, 255, 0.5);
      --border: rgba(100, 200, 255, 0.2);
      --border-hover: rgba(100, 217, 255, 0.6);
      --success: #00ff88;
      --row-even: rgba(0, 0, 0, 0.2);
      --row-hover: rgba(100, 217, 255, 0.1);
      --table-header: linear-gradient(90deg, rgba(100, 217, 255, 0.15), rgba(0, 102, 255, 0.1));
    }
    [data-theme="light"] {
      --bg-primary: #f0f4f8;
      --bg-secondary: #e2e8f0;
      --bg-container: rgba(255, 255, 255, 0.9);
      --text-primary: #1a202c;
      --text-secondary: #4a5568;
      --accent: #0066ff;
      --accent-glow: rgba(0, 102, 255, 0.3);
      --border: rgba(0, 102, 255, 0.2);
      --border-hover: rgba(0, 102, 255, 0.5);
      --success: #059669;
      --row-even: rgba(0, 102, 255, 0.04);
      --row-hover: rgba(0, 102, 255, 0.08);
      --table-header: linear-gradient(90deg, rgba(0, 102, 255, 0.08), rgba(0, 102, 255, 0.04));
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
      background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 20px;
      transition: background 0.4s, color 0.4s;
    }
    .container {
      max-width: 1000px;
      margin: 0 auto;
      background: var(--bg-container);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      animation: slideIn 0.6s ease-out;
    }
    @keyframes slideIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    h1 {
      font-size: 2.5em; font-weight: 700;
      background: linear-gradient(120deg, #64d9ff, #0066ff, #ff00ff, #64d9ff);
      background-size: 300% 300%;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 10px;
      animation: gradient 8s ease infinite;
    }
    @keyframes gradient { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
    p { font-size: 1.05em; margin-bottom: 15px; color: var(--text-secondary); }
    a { color: var(--accent); }
    .nav-link { display: inline-block; margin-bottom: 20px; color: var(--accent); text-decoration: none; font-weight: 600; }
    .nav-link:hover { text-decoration: underline; }
    .match-list { list-style: none; margin-top: 20px; }
    .match-item {
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
      padding: 16px 20px;
      border: 2px solid var(--border); border-radius: 12px;
      margin-bottom: 12px;
      background: linear-gradient(135deg, rgba(100, 217, 255, 0.05), rgba(0, 102, 255, 0.03));
      transition: all 0.3s;
    }
    .match-item:hover { border-color: var(--accent); box-shadow: 0 0 15px var(--accent-glow); transform: translateY(-2px); }
    .match-title { font-weight: 600; color: var(--text-primary); font-size: 1.1em; }
    .match-date { font-size: 0.85em; color: var(--text-secondary); }
    .match-actions a {
      display: inline-block; padding: 8px 16px; border-radius: 8px;
      background: linear-gradient(135deg, #0066ff, #00d4ff); color: #fff;
      text-decoration: none; font-weight: 600; font-size: 0.9em;
      transition: all 0.3s;
    }
    .match-actions a:hover { transform: translateY(-1px); box-shadow: 0 4px 15px rgba(0, 102, 255, 0.4); }
    .empty { text-align: center; padding: 40px; color: var(--text-secondary); }
    .top-bar { display: flex; justify-content: flex-end; gap: 12px; margin-bottom: 16px; }
    .theme-toggle {
      background: transparent; border: 2px solid var(--border); color: var(--text-primary);
      padding: 8px 16px; border-radius: 8px; cursor: pointer; font-size: 0.9em; font-weight: 600;
      transition: all 0.3s;
    }
    .theme-toggle:hover { border-color: var(--accent); box-shadow: 0 0 10px var(--accent-glow); }
    @media (max-width: 768px) { .container { padding: 25px; } h1 { font-size: 1.8em; } }
  </style>
</head>
<body>
  <div class="container">
    <div class="top-bar">
      <button class="theme-toggle" id="themeToggle">🌙 Dark</button>
    </div>
    <a href="/" class="nav-link">← Back to Scoreboard</a>
    <h1>📚 Match History</h1>
    <p>Previously loaded matches stored in the local database</p>

    <% if (matches && matches.length > 0) { %>
      <ul class="match-list">
        <% matches.forEach((m) => { %>
          <li class="match-item">
            <div>
              <div class="match-title"><%= m.title || 'Untitled Match' %></div>
              <div class="match-date">Saved: <%= m.fetched_at %></div>
            </div>
            <div class="match-actions">
              <a href="/history/load?url=<%= encodeURIComponent(m.url) %>">Load</a>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <div class="empty">
        <p>No matches saved yet. Load a match from the <a href="/">scoreboard</a> and it will appear here.</p>
      </div>
    <% } %>
  </div>

  <script>
    (function() {
      const toggle = document.getElementById('themeToggle');
      const saved = localStorage.getItem('theme') || 'dark';
      if (saved === 'light') { document.documentElement.setAttribute('data-theme', 'light'); toggle.textContent = '☀️ Light'; }
      toggle.addEventListener('click', function() {
        const current = document.documentElement.getAttribute('data-theme');
        if (current === 'light') { document.documentElement.removeAttribute('data-theme'); localStorage.setItem('theme', 'dark'); toggle.textContent = '🌙 Dark'; }
        else { document.documentElement.setAttribute('data-theme', 'light'); localStorage.setItem('theme', 'light'); toggle.textContent = '☀️ Light'; }
      });
    })();
  </script>
</body>
</html>
